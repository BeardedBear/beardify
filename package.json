{
  "name": "beardify",
  "version": "0.8.6",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "lint": "vue-tsc --noEmit && eslint src/**/*.{vue,ts} && stylelint ./src/**/*.{vue,scss}",
    "build": "bun run lint && vite build",
    "fix": "eslint src/**/*.{vue,ts} --fix && stylelint ./src/**/*.{vue,scss} --fix",
    "preview": "bun run build && vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:build:debug": "tauri build --debug",
    "vite:dev-build": "vite build --mode development",
    "build:ci": "vite build",
    "build:app": "bun run tauri build && bun run scripts/package-release.ts",
    "release": "bun run scripts/release.ts"
  },
  "dependencies": {
    "@lucide/vue": "^1.21.0",
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-deep-link": "^2.4.9",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "@vueuse/motion": "^3.0.3",
    "crypto-js": "^4.2.0",
    "date-fns": "^4.4.0",
    "dompurify": "^3.4.11",
    "flag-icons": "^7.5.0",
    "form-urlencoded": "^6.1.7",
    "ky": "^2.0.2",
    "oxlint": "^1.71.0",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "pkce-challenge": "^6.0.0",
    "vue": "^3.5.38",
    "vue-router": "^5.1.0",
    "vue-slicksort": "^2.0.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@rushstack/eslint-patch": "^1.16.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@tauri-apps/cli": "^2.11.3",
    "@types/dompurify": "^3.2.0",
    "@types/node": "^26.0.0",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/compiler-sfc": "^3.5.38",
    "@vue/eslint-config-typescript": "^14.9.0",
    "@vueuse/core": "^14.3.0",
    "eslint": "^10.5.0",
    "eslint-plugin-perfectionist": "^5.9.1",
    "eslint-plugin-vue": "^10.9.2",
    "globals": "^17.7.0",
    "normalize.css": "^8.0.1",
    "postcss": "^8.5.15",
    "postcss-html": "^1.8.1",
    "sass": "^1.101.0",
    "stylelint": "^17.13.0",
    "stylelint-config-html": "^1.1.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-order": "^8.1.1",
    "stylelint-scss": "^7.2.0",
    "typescript": "6.0.3",
    "vite": "^8.1.0",
    "vite-plugin-static-copy": "^4.1.1",
    "vue-eslint-parser": "^10.4.1",
    "vue-tsc": "^3.3.5"
  },
  "optionalDependencies": {
    "@esbuild/linux-x64": "^0.28.1"
  }
}
